# Copy this file to .env next to router_client_traffic.py or to the directory
# where you run the script.
#
# Keenetic router SSH address. Usually the router LAN IP.
ROUTER_HOST=192.168.1.1

# Keenetic router SSH user.
ROUTER_USER=admin

# Keenetic router SSH password. Leave empty if SSH key auth works.
ROUTER_PASSWORD=change-me

# Optional defaults. Command-line arguments override these.
ROUTER_INTERVAL=3
ROUTER_TIMEOUT=25
ROUTER_DNS_TIMEOUT=1
ROUTER_RETRIES=3

# DNS watcher only: how many recent router log lines to read each poll.
ROUTER_LOG_LINES=300
